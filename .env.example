# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Project Settings > API no painel do Supabase).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Só usada em scripts server-side (seed de usuários). NUNCA exponha no client
# nem prefixe com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
